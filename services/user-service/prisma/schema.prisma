// user-service/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("USER_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
  
}

enum EnrollmentStatus {
  ENROLLED      
  COMPLETED     
  DROPPED      
}

enum NodeProgressStatus {
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

// ================= USER PROGRESS =================

model USER_ROADMAPS_PROGRESS {
  id                      Int                   @id @default(autoincrement())
  
  user_id                 Int
  roadmap_id              Int
  
  enrollment_status       EnrollmentStatus
  completion_percentage   Int
  total_credits_earned    Int
  total_credits_required  Int

  userNodeProgress        USER_NODE_PROGRESS[]

  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  @@unique([user_id, roadmap_id])
  @@index([user_id])
  @@index([roadmap_id])
  @@map("user_roadmaps")
}

model USER_NODE_PROGRESS {
  id                      Int                   @id @default(autoincrement())
  
  user_roadmap_id         Int
  userRoadmap             USER_ROADMAPS_PROGRESS         @relation(fields: [user_roadmap_id], references: [id], onDelete: Cascade)
  
  course_node_id          Int
  
  status                  NodeProgressStatus
  credits_earned          Int

  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  @@unique([user_roadmap_id, course_node_id])
  @@index([user_roadmap_id])
  @@index([course_node_id])
  @@map("user_node_progress")
}