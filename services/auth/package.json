{
  "name": "gupjob-auth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only main.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:dbpush": "prisma db push",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "cross-env AUTH_DATABASE_URL=postgresql://gupjob:gupjob_pass@localhost:5432/gupjob_test_db?schema=public jest --config ./src/__tests__/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/client": "5.22.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "nodemailer": "^7.0.11",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "prisma": "5.22.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^29.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-jwt": "^3.0.6",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
