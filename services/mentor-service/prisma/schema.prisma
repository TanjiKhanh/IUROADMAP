// Mentor service schema (mentor-service)
// Models: Mentor, MentorSkill, MentorAvailability (simple)
// Datasource uses MENTOR_DATABASE_URL

datasource db {
  provider = "postgresql"
  url      = env("MENTOR_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MentorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model MentorProfile {
  userId         Int      @id
  bio            Json?
  hourlyRate     Decimal? @db.Decimal(10,2)
  approvalStatus MentorApprovalStatus @default(PENDING)
  cvUrl          String?
  linkedinUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MentorVerificationRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  documents   Json     // array of { url, filename, contentType }
  summary     String?
  status      MentorApprovalStatus @default(PENDING) // PENDING | APPROVED | REJECTED
  submittedAt DateTime @default(now())
  reviewedBy  Int?
  reviewedAt  DateTime?
  reviewNote  String?
}