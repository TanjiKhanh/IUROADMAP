// Mentor service schema (mentor-service)
// Models: Mentor, MentorSkill, MentorAvailability (simple)
// Datasource uses MENTOR_DATABASE_URL

datasource db {
  provider = "postgresql"
  url      = env("MENTOR_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}


model MentorProfile {
  userId         Int      @id
  bio            String?
  cvUrl          String?
  linkedinUrl    String?
  industry        String?  // For recommendation engine (e.g., "BUSINESS_ANALYTICS", "MARKETING")
  skills         String[] // list of skills (kept for compatibility with auth service payloads)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}



model MentorSkill {
  id         Int      @id @default(autoincrement())
  mentorId   Int
  skillName  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([mentorId])
}

