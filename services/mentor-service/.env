# Copy this file to .env in services/auth/ and adjust values for your environment.

# Postgres connection (used by Prisma)
MENTOR_DATABASE_URL="postgresql://gupjob:gupjob_pass@localhost:5432/gupjob_mentor?schema=public"

# JWT settings
JWT_SECRET=supersecret_dev_key
JWT_EXPIRATION=3600s

# NestJS service port
PORT=4001

# Node environment
NODE_ENV=development

# Auth Service URL
AUTH_SERVICE_URL=http://localhost:3000

# Admin Service URL
ADMIN_SERVICE_URL=http://localhost:4100

# User Service URL
USER_SERVICE_URL=http://localhost:4000

# Internal API key for Mentor Service (for secure communication between services)
MENTOR_SERVICE_API_KEY=super-secret-gupjob-internal-key-998877
