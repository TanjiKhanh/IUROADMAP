              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"student_token\", jsonData.access_token);",
                  "    pm.collectionVariables.set(\"student_id\", jsonData.user.id);",
                  "    console.log(\"✅ Student Token Set\");",
                  "}"
