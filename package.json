{
  "name": "iuroadmap",
  "version": "1.0.0",
  "description": "AI-Powered Career Roadmap Platform",
  "private": true,
  "workspaces": [
    "services/api-gateway",
    "services/auth",
    "services/admin-service",
    "services/mentor-service",
    "services/user-service"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "# ========== SETUP =========": "",
    "install-all": "npm ci --workspaces",
    "bootstrap": "npm install && npm run build --workspaces",
    "clean": "npm run clean --workspaces && node -e \"require('fs').rmSync('node_modules', {recursive: true, force: true})\" && node -e \"require('fs').rmSync('coverage', {recursive: true, force: true})\"",

    "# ========== DEVELOPMENT =========": "",
    "dev": "npm run start:dev --workspaces",
    "start": "npm run start --workspaces",

    "# ========== BUILD =========": "",
    "build": "npm run build --workspaces",
    "prebuild": "npm run clean",

    "# ========== DATABASE MIGRATIONS =========": "",
    "migrate": "npm run migrate --workspaces --if-present",

    "# ========== LINTING & FORMATTING =========": "",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "validate": "npm run lint && npm run format:check && npm run typecheck",
    "validate:fix": "npm run lint:fix && npm run format",

    "# ========== TYPE CHECKING =========": "",
    "typecheck": "npm run typecheck --workspaces --if-present",

    "# ========== UNIT TESTS (No Database) =========": "",
    "test": "npm run test:unit --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:unit:watch": "npm run test:unit:watch --workspaces --if-present",
    "test:unit:debug": "npm run test:unit:debug --workspaces --if-present"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0"
  }
}